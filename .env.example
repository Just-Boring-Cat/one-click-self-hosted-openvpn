# Copy to .env and fill in values for your server.
# Do not put real secrets in this example file.

VPN_PROVIDER=hetzner
VPN_SERVER_IPV4=
VPN_SERVER_SSH_USER=vpnadmin
VPN_SERVER_SSH_KEY=local/ssh/id_ed25519
VPN_SERVER_SSH_COMMAND="ssh -i local/ssh/id_ed25519 vpnadmin@<server-ip>"
VPN_CLIENT_NAME=primary
VPN_CLIENT_PROFILE=local/clients/primary.ovpn
VPN_PROVIDER_FIREWALL_READY=no
VPN_OPENVPN_PORT=1194
VPN_OPENVPN_PROTO=udp
